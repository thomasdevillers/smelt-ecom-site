# Paystack — copy this file to .env.local and fill in your secret key.
# Get keys from https://dashboard.paystack.com/#/settings/developers
# Use the TEST secret key (sk_test_...) while developing, LIVE (sk_live_...) in production.
# This is a SECRET key: it must never be committed or exposed to the browser.
PAYSTACK_SECRET_KEY=

# Resend (order emails). Leave RESEND_API_KEY blank to disable sending.
RESEND_API_KEY=
# Sender address. Must be on a domain verified in Resend. Defaults to Resend's
# sandbox (onboarding@resend.dev) if blank, which can ONLY deliver to your own
# Resend account email. saunahat.co.za is verified, so use:
#   ORDER_FROM_EMAIL=Smelt <orders@saunahat.co.za>
ORDER_FROM_EMAIL=
# Where new-order alerts are sent (you). Comma-separated for multiple recipients.
ORDER_NOTIFY_EMAIL=

# Postgres connection string (Neon, Supabase, etc.). Use the POOLED connection
# string for serverless deploys. Leave blank to run without order persistence.
# Example: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=

# Absolute site URL used for links and images inside emails (no trailing slash).
# Required for correct links from the cron/admin flows, which have no request
# origin to infer it from. Example: https://saunahat.co.za
SITE_URL=

# Secret the abandoned-cart cron route checks in the Authorization header.
# Vercel Cron sends "Authorization: Bearer $CRON_SECRET" automatically when set.
CRON_SECRET=

# Single shared password gating the /admin fulfillment dashboard. Leave blank to
# keep /admin closed (every admin request 401s until this is set).
ADMIN_PASSWORD=
